{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for all windows",
  "windows": ["main", "popout"],
  "permissions": [
    "core:default",
    "opener:default",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load",
    "sql:allow-close",
    "sql:default",
    "dialog:allow-open",
    "fs:allow-read-text-file",
    "fs:allow-exists",
    {"identifier": "fs:allow-read-text-file", "allow": [{"path": "$DOCUMENT/**/*"}, {"path": "$DESKTOP/**/*"}, {"path": "$DOWNLOAD/**/*"}, {"path": "/Users/chy/Projects/Personal/present.ly/**/*"}]},
    {"identifier": "fs:allow-exists", "allow": [{"path": "$DOCUMENT/**/*"}, {"path": "$DESKTOP/**/*"}, {"path": "$DOWNLOAD/**/*"}, {"path": "/Users/chy/Projects/Personal/present.ly/**/*"}]},
    "core:event:allow-emit",
    "core:event:allow-emit-to",
    "core:event:allow-listen",
    "core:window:allow-create",
    "core:window:allow-set-focus",
    "core:window:allow-show",
    "core:window:allow-close"
  ]
}