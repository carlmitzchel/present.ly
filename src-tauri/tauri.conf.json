{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "presently",
  "version": "0.1.0-beta.1",
  "identifier": "com.chy.presently",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:8080",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:app.db"]
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Teleprompter",
        "width": 1024,
        "height": 768
      },
      {
        "label": "popout",
        "title": "Teleprompter Display",
        "width": 800,
        "height": 600,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "decorations": true
      
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/ffmpeg"
    ]
  }
}
